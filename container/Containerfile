ARG N8N_VERSION=1.123.28

# Stage 1: Source - extract n8n from official Docker Hub image
FROM docker.io/n8nio/n8n:${N8N_VERSION} AS source

# Stage 2: Builder - rebuild sqlite3 native module for Node.js 22 + glibc (RHEL)
FROM registry.access.redhat.com/ubi9/nodejs-22:latest AS builder

USER 0

COPY --from=source /usr/local/lib/node_modules /usr/local/lib/node_modules

WORKDIR /usr/local/lib/node_modules/n8n/node_modules/.pnpm/sqlite3@5.1.7/node_modules/sqlite3
RUN rm -rf build prebuilds && \
    ./node_modules/.bin/prebuild-install -r napi || \
    (echo "prebuild-install failed, falling back to node-gyp" && npx --yes node-gyp rebuild)

# Stage 3: Runtime - minimal UBI image
FROM registry.access.redhat.com/ubi9/nodejs-22-minimal:latest

ARG N8N_VERSION=1.123.28

LABEL name="n8n" \
      vendor="n8n GmbH" \
      version="${N8N_VERSION}" \
      release="1" \
      summary="n8n workflow automation on Red Hat UBI 9" \
      description="n8n is a fair-code workflow automation tool. Repackaged from docker.io/n8nio/n8n:${N8N_VERSION} onto Red Hat UBI 9 with Node.js 22." \
      io.k8s.display-name="n8n Workflow Automation" \
      io.k8s.description="n8n workflow automation on Red Hat UBI 9" \
      io.openshift.tags="n8n,workflow,automation,ai,mcp" \
      io.openshift.expose-services="5678:http" \
      source-image="docker.io/n8nio/n8n:${N8N_VERSION}"

USER 0

RUN microdnf install -y shadow-utils && \
    microdnf clean all && \
    useradd -r -u 1000 -g 0 -s /sbin/nologin -d /home/node node && \
    mkdir -p /home/node/.n8n /data && \
    chown -R 1000:0 /home/node /data && \
    chmod -R g=u /home/node /data

COPY --from=builder --chown=1000:0 /usr/local/lib/node_modules /usr/local/lib/node_modules
RUN ln -s /usr/local/lib/node_modules/n8n/bin/n8n /usr/local/bin/n8n

ENV N8N_USER_FOLDER=/data \
    N8N_PORT=5678 \
    NODE_ENV=production

EXPOSE 5678

USER 1000

WORKDIR /home/node

ENTRYPOINT ["n8n"]
